# ============================================================
# SISTEMA DIGITAL EGIS — Variables de entorno
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Cambia TODOS los valores marcados con [CAMBIAR]
#   3. Nunca subas .env a GitHub (ya está en .gitignore)
# ============================================================

# ----------------------------------------------------------
# BASE DE DATOS
# ----------------------------------------------------------
POSTGRES_PASSWORD=[CAMBIAR_contrasena_segura_minimo_20_chars]

# ----------------------------------------------------------
# REDIS
# ----------------------------------------------------------
REDIS_PASSWORD=[CAMBIAR_contrasena_redis_segura]

# ----------------------------------------------------------
# KEYCLOAK
# ----------------------------------------------------------
KEYCLOAK_ADMIN_PASSWORD=[CAMBIAR_contrasena_admin_keycloak]
KEYCLOAK_CLIENT_SECRET=[CAMBIAR_secret_generado_en_keycloak]

# ----------------------------------------------------------
# CHROMADB (Vector Store RAG)
# ----------------------------------------------------------
CHROMA_TOKEN=[CAMBIAR_token_largo_aleatorio]

# ----------------------------------------------------------
# JWT
# ----------------------------------------------------------
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=[CAMBIAR_secret_jwt_64_bytes_hex]

# ----------------------------------------------------------
# OLLAMA (no requiere cambios en local)
# ----------------------------------------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL_ARIA=qwen3:4b
OLLAMA_MODEL_INTERNAL=qwen3:14b

# ----------------------------------------------------------
# ENTORNO
# ----------------------------------------------------------
NODE_ENV=development
